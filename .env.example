# =============================================================
# DevFlow Agent — Environment Variables Template
# =============================================================
# Copy this file: cp .env.example .env
# Then fill in your keys. All APIs listed have a free tier.
# NEVER commit .env to git. It is already in .gitignore.
# =============================================================

# ------------------------------------------------------------
# REQUIRED — Primary LLM provider
# Get yours at: https://console.groq.com → API Keys
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------
# OPTIONAL — Raises GitHub API rate limit from 60 to 5,000/hr
# Get yours at: https://github.com/settings/tokens
#   → Generate new (classic) → check public_repo scope only
# ------------------------------------------------------------
GITHUB_TOKEN=your_github_personal_access_token_here

# ------------------------------------------------------------
# OPTIONAL — LLM fallback #1 (Google Gemini Flash)
# Get yours at: https://aistudio.google.com → Get API Key
# ------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------------------------
# OPTIONAL — LLM fallback #2 (OpenRouter, free Llama model)
# Get yours at: https://openrouter.ai/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ------------------------------------------------------------
# Flask server configuration
# ------------------------------------------------------------
FLASK_PORT=5000
FLASK_DEBUG=false
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Streamlit → Flask communication
# Change to http://backend:5000 when using docker-compose
# ------------------------------------------------------------
FLASK_URL=http://localhost:5000

# ------------------------------------------------------------
# CORS — comma-separated list of allowed origins
# ------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:8501
